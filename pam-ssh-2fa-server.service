[Unit]
Description=PAM SSH 2FA Approval Server
Documentation=file:/etc/pam-ssh-2fa/README.md
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /etc/pam-ssh-2fa/approval_server.py
Restart=always
RestartSec=5

# Security hardening
User=root
Group=root
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadWritePaths=/var/run/pam-ssh-2fa /var/log

# Resource limits
LimitNOFILE=1024
MemoryMax=128M

[Install]
WantedBy=multi-user.target
