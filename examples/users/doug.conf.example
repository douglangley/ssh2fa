# =============================================================================
# Per-User PAM SSH 2FA Configuration
# =============================================================================
#
# This file configures notifications for a specific user.
# Location: /etc/pam-ssh-2fa/users/<username>.conf
#
# Only certain sections are used from per-user configs:
#   [notification]  - Native provider selection (recommended, see below)
#   [pushover]      - Native Pushover recipient key
#   [ntfy]          - Native ntfy publish URL/token
#   [notifications] - Legacy Apprise URLs and templates
#   [auth]          - Authentication method
#
# All other settings come from the main /etc/pam-ssh-2fa/config.ini
#
# This example is for a user who prefers Pushover with link-based auth,
# using the NATIVE Pushover provider (recommended -- see
# AUDIT_REMEDIATION_AND_ADMIN_PLAN.md Phase 3). Native providers use only
# the Python standard library, not the Apprise dependency.
#
# SETUP:
# 1. Copy this file: sudo cp doug.conf.example /etc/pam-ssh-2fa/users/doug.conf
# 2. Ask an administrator to register a Pushover application once (globally,
#    see [pushover] app_token_file in /etc/pam-ssh-2fa/config.ini) --
#    you only need your own recipient user key below, from your
#    Pushover dashboard at https://pushover.net (top right after login)
# 3. Edit YOUR_USER_KEY below
# 4. Set permissions: sudo chmod 600 /etc/pam-ssh-2fa/users/doug.conf
#
# =============================================================================

[notification]

# Select the native Pushover provider for this user.
providers = pushover


[pushover]

# Your Pushover recipient user key (30 case-sensitive alphanumeric
# characters), from your Pushover dashboard. This identifies YOU as the
# recipient; the application token (shared by all users) is configured
# once, globally, by an administrator.
user_key = YOUR_30_CHARACTER_PUSHOVER_USER_KEY


[auth]

# Authentication method for this user
#
# Options:
#   code - Send a code (length set globally by [codes] length), user types it in
#   link - Send an approval link, user opens it and explicitly confirms
#   both - Send both, user can type code OR open the link then press Enter
#   none - Skip 2FA entirely for this user
#
# Pushover supports clickable links, so "link" or "both" work great.
#
method = link


# -----------------------------------------------------------------------------
# ALTERNATIVE: legacy Apprise-based Pushover (only if not using native above)
# -----------------------------------------------------------------------------
# Do not set both [notification] providers and [notifications] apprise_urls
# for the same user -- pick one. Uncomment the two lines below and remove
# the [notification]/[pushover] sections above if you need Apprise's
# broader provider support instead of the native Pushover provider.
#
# [notifications]
# apprise_urls = pover://YOUR_USER_KEY@YOUR_APP_TOKEN
